# Required - Klaviyo private API key
KLAVIYO_API_KEY=pk_your_private_key_here

# Shopify - Dev Dashboard app (recommended for new apps, required since Jan 2026)
SHOPIFY_STORE=your-store.myshopify.com
SHOPIFY_CLIENT_ID=your_client_id
SHOPIFY_CLIENT_SECRET=shpss_your_secret

# Shopify - Legacy custom app (for existing apps created before Jan 2026)
# SHOPIFY_STORE=your-store.myshopify.com
# SHOPIFY_ACCESS_TOKEN=shpat_your_token_here

# Optional - Override auto-discovered conversion metric ID
KLAVIYO_CONVERSION_METRIC_ID=

# Optional - Logging level (debug | info | warn | error)
LOG_LEVEL=info
